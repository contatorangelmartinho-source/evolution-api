# Evolution API - Configuração
# Estas variáveis são sobrescritas pelas variáveis de ambiente do servidor

SERVER_TYPE=http
SERVER_PORT=8080

# Banco de dados - será preenchido pelo ambiente
DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=${DATABASE_CONNECTION_URI}
DATABASE_URL=${DATABASE_URL}

DATABASE_CONNECTION_CLIENT_NAME=pg
DATABASE_SAVE_DATA_INSTANCE=true
DATABASE_SAVE_DATA_MESSAGES=true
DATABASE_SAVE_DATA_CONTACTS=true
DATABASE_SAVE_MESSAGE_UPDATE=true

# Auth
AUTHENTICATION_TYPE=apikey
AUTHENTICATION_API_KEY=${AUTHENTICATION_API_KEY}

# App
LOG_LEVEL=ERROR
LOG_COLOR=true
DEL_INSTANCE=false
QRCODE_LIMIT=10
